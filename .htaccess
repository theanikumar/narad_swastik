<IfModule mod_rewrite.c>
    RewriteEngine On

    # Redirect all requests to public/ directory (skip if already in public/)
    RewriteRule ^public/ - [L]
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

# Deny direct access to sensitive directories
<IfModule mod_autoindex.c>
    Options -Indexes
</IfModule>

# Protect sensitive files
<FilesMatch "\.(env|json|lock|md|log|sql)$">
    Require all denied
</FilesMatch>

# Protect sensitive directories
<IfModule mod_rewrite.c>
    RewriteRule ^(app|config|database|routes|storage|vendor)/ - [F,L]
</IfModule>
